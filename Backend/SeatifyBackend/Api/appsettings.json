{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedOrigins": [
    "http://localhost:4200",
    "https://localhost:4200"
  ],
  "Database": {
    "Provider": "SqlServer"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=SeatifyDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "CHANGE_ME_IN_APPSETTINGS_DEVELOPMENT_JSON_USE_AT_LEAST_32_CHARS",
    "Issuer": "Seatify.Api",
    "Audience": "Seatify.Frontend",
    "AccessTokenMinutes": 60
  },
  "Resend": {
    "ApiToken": ""
  },
  "AllowedHosts": "*"
}